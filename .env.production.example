# ── Production environment — nuujf backend ───────────────────
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to git.

# ── Django Core ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_python_secrets_token_hex_50
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=api.nuujf.uz,nuujf.uz

# ── Security (enable all in production) ──────────────────────
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=63072000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=nuujf_db
DB_USER=nuujf_user
DB_PASSWORD=CHANGE_ME_strong_db_password_here
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
# Must match the --requirepass value in docker-compose.prod.yml
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here
REDIS_URL=redis://:CHANGE_ME_strong_redis_password_here@redis:6379/1

# ── External integrations ─────────────────────────────────────
HEMIS_TOKEN=CHANGE_ME_hemis_api_token

# ── Docker registry (used by docker-compose.prod.yml) ────────
REGISTRY=ghcr.io
IMAGE_TAG=latest
